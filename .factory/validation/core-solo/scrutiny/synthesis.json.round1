    {
      "featureId": "implement-solo-live-play-surface",
      "severity": "blocking",
      "description": "If the trie fails to load, reveal/timeout leaves the round stuck in `finishing` forever instead of surfacing a clear end-state error. `finalizeSoloRound()` moves the round to `phase: 'finishing'` for any non-ready dictionary state, but the follow-up effect only resolves when `dictionary.state === 'ready'`, so the permanent error case never reaches a terminal visible failure state."
    }
  ],
